# AssemblyAI Configuration
# Get your API key at https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Token Service Configuration
PORT=3001
TOKEN_EXPIRES_IN=60
CORS_ORIGINS=http://localhost:3000

# Device Authentication (token service mode only)
# Comma-separated list of allowed device API keys
ALLOWED_DEVICE_KEYS=device-key-001,device-key-002

# Device Simulator Configuration
TOKEN_SERVICE_URL=http://localhost:3001
DEVICE_API_KEY=device-key-001
DEVICE_ID=itranslate-device-001

# Audio Configuration
SAMPLE_RATE=16000
CHANNELS=1
CHUNK_DURATION_MS=100

# Language Configuration
DEFAULT_SOURCE_LANGUAGE=en

# Feature Flags
PROMPTING_MODE=default
ENABLE_SPEAKER_DIARIZATION=false
